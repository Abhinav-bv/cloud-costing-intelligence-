# Environment Configuration
# Copy this to .env and fill in your AWS credentials

# AWS RDS Configuration
AWS_RDS_HOST=your-rds-instance.region.rds.amazonaws.com
AWS_RDS_PORT=5432
AWS_RDS_DB_NAME=cloud_costing
AWS_RDS_USER=admin
AWS_RDS_PASSWORD=your_secure_password_here
AWS_RDS_ENGINE=postgres

# Options: postgres, mysql, mariadb
# AWS Region
AWS_REGION=us-east-1
AWS_PROFILE=default

# Local SQLite Configuration
LOCAL_DB_FILE=metrics.db

# Sync Mode - determines which database(s) to use
# Options: local (SQLite only), aws (RDS only), both (sync both)
SYNC_MODE=both

# Boolean - use AWS by default
USE_AWS=False
