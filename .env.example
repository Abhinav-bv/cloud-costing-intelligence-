# ============================================================================
# CLOUD COST INTELLIGENCE - DEPLOYMENT CONFIGURATION
# ============================================================================
# Copy this to .env and fill in your values
# Different deployments use different subsets of these variables

# ============================================================================
# AWS CREDENTIALS (Required for backend data collection)
# ============================================================================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_PROFILE=default

# ============================================================================
# DATABASE CONFIGURATION (Local Development)
# ============================================================================
# SQLite database file path (local development only)
LOCAL_DB_FILE=metrics.db

# ============================================================================
# FLASK/BACKEND CONFIGURATION
# ============================================================================
# Flask environment: production or development
FLASK_ENV=production
FLASK_DEBUG=false

# For Render deployment, this is set automatically
# PORT will be injected by Render, defaults to 5000 locally
# PORT=5000

# ============================================================================
# FRONTEND CONFIGURATION (Vercel)
# ============================================================================
# API URL that React frontend uses
# For development: http://localhost:5000
# For production: https://your-render-backend.onrender.com
VITE_API_URL=https://your-app-name.onrender.com

# ============================================================================
# DATA PIPELINE SETTINGS
# ============================================================================
# CloudWatch namespace to monitor
CLOUDWATCH_NAMESPACE=HackathonMetrics

# Resource IDs to monitor (comma-separated)
# Examples: i-0123456789abcdef0,lambda-function-name,rds-instance-id
MONITORED_RESOURCES=i-0123456789abcdef0

# Data collection interval (minutes)
COLLECTION_INTERVAL=5

# Data retention period (days)
DATA_RETENTION_DAYS=90

# ============================================================================
# OUTPUT CONFIGURATION
# ============================================================================
# Directory where pipeline outputs files (CSV, reports)
OUTPUT_DIR=./output

# ML-ready CSV filename
ML_READY_CSV=ml_ready_data.csv

# ============================================================================
# AWS COST ANALYSIS (S3 Storage)
# ============================================================================
# S3 bucket containing cost reports
COST_REPORT_BUCKET=hackathon-cost-reports-457563661765-us-east-1-an

# S3 key for cost report JSON
COST_REPORT_KEY=cost_report.json

# ============================================================================
# LOGGING
# ============================================================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file path
LOG_FILE=pipeline.log

